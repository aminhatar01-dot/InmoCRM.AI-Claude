# ============================================================
# InmoCRM.AI — Variables de Entorno
# Copiá este archivo como .env.local y completá los valores
# NUNCA subas .env.local al repositorio
# ============================================================

# ─── Supabase ───────────────────────────────────────────────
# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (solo servidor, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Meta (WhatsApp, Instagram, Facebook) ───────────────────
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_VERIFY_TOKEN=secreto-para-verificar-webhook
META_APP_SECRET=

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── MercadoPago ────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=

# ─── Google Calendar ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Tokko Broker ───────────────────────────────────────────
TOKKO_API_KEY=

# ─── Aplicación ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.inmocrm.ai

# Clave AES-256 para encriptar credenciales de integraciones (32 chars)
CLAVE_ENCRIPTACION=
